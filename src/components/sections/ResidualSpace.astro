---
import Surface from '../primitives/Surface.astro';

export interface Props {
  height?: 'normal' | 'compact';
}

const { height = 'normal' } = Astro.props;
---

<section class="residual" data-height={height} aria-label="Intervalo visual">
  <Surface material="inverse" as="div">
    <span class="sr-only">Pausa visual entre secoes.</span>
  </Surface>
</section>

<style>
  .residual {
    height: var(--space-residual-height);
    position: relative;
    z-index: 1;
  }

  .residual::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    z-index: 1;
  }

  .residual[data-height='compact'] {
    height: calc(var(--space-residual-height) / 2);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
