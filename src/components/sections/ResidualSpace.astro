---
export interface Props {
  height?: 'normal' | 'compact';
}

const { height = 'normal' } = Astro.props;
---

<div class="residual reveal" data-height={height} role="separator" aria-label="Intervalo visual" style="--settle-rotate:-0.2deg;">
  <span class="residual__tape residual__tape--a" aria-hidden="true"></span>
  <span class="residual__tape residual__tape--b" aria-hidden="true"></span>
  <span class="residual__label" aria-hidden="true">colado / v.01</span>
</div>

<style>
  /* Faixa que "cola" a secao anterior a proxima. */
  .residual {
    position: relative;
    z-index: 4;
    height: 4px;
    /* Puxa as secoes para dentro: sensacao de recortes sobrepostos. */
    margin-block: calc(-1 * var(--space-gap-paragraph)) var(--space-gap-section);
    background: repeating-linear-gradient(
      90deg,
      var(--color-border-primary) 0,
      var(--color-border-primary) 10px,
      transparent 10px,
      transparent 18px
    );
    opacity: 0.85;
  }

  /* Pedacos de fita adesiva atravessando a emenda. */
  .residual__tape {
    position: absolute;
    top: -12px;
    height: 28px;
    background: color-mix(in srgb, var(--color-accent-stamp) 20%, transparent);
    border: 1px dashed color-mix(in srgb, var(--color-border-primary) 35%, transparent);
    box-shadow: 1px 2px 3px rgba(0, 0, 0, 0.08);
    pointer-events: none;
  }

  .residual__tape::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 5px,
      color-mix(in srgb, var(--color-border-primary) 12%, transparent) 5px,
      color-mix(in srgb, var(--color-border-primary) 12%, transparent) 6px
    );
  }

  .residual__tape--a {
    left: 22%;
    width: 96px;
    transform: rotate(-4deg);
  }

  .residual__tape--b {
    right: 18%;
    width: 76px;
    transform: rotate(3.5deg);
    background: color-mix(in srgb, var(--foundation-color-terminal-green, #7bc942) 18%, transparent);
  }

  .residual__label {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%) rotate(-1deg);
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-micro);
    letter-spacing: var(--type-tracking-navigation);
    color: var(--color-text-secondary);
    opacity: 0.55;
    pointer-events: none;
  }

  .residual[data-height='compact'] {
    margin-block: var(--space-gap-paragraph);
    height: 2px;
  }
</style>
