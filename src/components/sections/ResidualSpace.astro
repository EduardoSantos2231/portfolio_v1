---
export interface Props {
  height?: 'normal' | 'compact';
}

const { height = 'normal' } = Astro.props;
---

<hr class="residual" data-height={height} aria-label="Intervalo visual" />

<style>
  .residual {
    border: none;
    height: 4px;
    background-color: var(--color-border-primary);
    margin-block: var(--space-gap-section);
    opacity: 0.8;
    position: relative;
    z-index: 1;
  }

  .residual::after {
    content: '';
    position: absolute;
    top: -10px;
    left: 40%;
    width: 46px;
    height: 14px;
    background: var(--color-accent-stamp);
    opacity: 0.35;
    transform: rotate(-3deg);
    pointer-events: none;
  }

  .residual[data-height='compact'] {
    margin-block: var(--space-gap-paragraph);
    height: 2px;
  }

  .residual[data-height='compact']::after {
    width: 32px;
    left: 30%;
  }
</style>
