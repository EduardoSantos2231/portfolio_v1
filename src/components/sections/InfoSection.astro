---
import SectionTitle from '../compounds/SectionTitle.astro';
import Text from '../primitives/Text.astro';

interface Field {
  label: string;
  value: string;
  i18nKey: string;
}

interface ContactItem {
  label: string;
  value: string;
  href?: string;
  i18nKey: string;
}

export interface Props {
  fields: Field[];
  contacts: ContactItem[];
  closingQuote?: string;
}

const { fields, contacts, closingQuote } = Astro.props;
---

<section id="info" class="info" aria-label="Informacoes" data-i18n-aria="info.arialabel">
  <header class="info__header reveal" style="--settle-rotate:0deg;--reveal-origin:0% 50%;">
    <SectionTitle label="INFO" prefix="slash" i18nKey="info.title" voice="serif" size="headline" />
  </header>

  <div class="info__cards">
    <span class="collage-tape info__cards-tape" aria-hidden="true"></span>
    <div class="info__card info__card--about hard-shadow reveal" style="--settle-rotate:-0.9deg;--reveal-delay:60ms;--reveal-origin:20% 0%;">
      <span class="info__card-label">
        <Text voice="mono" size="small" color="secondary" as="span">
          <span data-i18n="about.cardLabel">FICHA TECNICA</span>
        </Text>
      </span>

      <div class="info__contact-lines">
        {fields.map(({ label, value, i18nKey }) => (
          <div class="info__contact-line">
            <span class="info__contact-link">
              <Text voice="mono" size="small" color="secondary" as="span">
                <span data-i18n={i18nKey}>{label}</span>
              </Text>
              <span class="info__contact-sep" aria-hidden="true">{'\u00B7'}</span>
              <Text voice="mono" size="small" color="primary" as="span">{value}</Text>
            </span>
          </div>
        ))}
      </div>
    </div>

    <div class="info__card info__card--contact hard-shadow reveal" style="--settle-rotate:0.8deg;--reveal-delay:200ms;--reveal-origin:80% 0%;">
      <span class="info__card-label">
        <Text voice="mono" size="small" color="secondary" as="span">
          <span data-i18n="contact.cardLabel">CONTATO</span>
        </Text>
      </span>

      <div class="info__contact-lines">
        {contacts.map((c) => (
          <div class="info__contact-line">
            <a href={c.href} class="info__contact-link">
              <Text voice="mono" size="small" color="secondary" as="span">
                <span data-i18n={c.i18nKey}>{c.label}</span>
              </Text>
              <span class="info__contact-sep" aria-hidden="true">{'\u00B7'}</span>
              <Text voice="mono" size="small" color="primary" as="span">{c.value}</Text>
            </a>
          </div>
        ))}
      </div>

      {closingQuote && (
        <div class="info__closing">
          <Text voice="serif" size="small" weight="italic" color="primary" as="p">
            {closingQuote}
          </Text>
        </div>
      )}
    </div>
  </div>

  <blockquote class="info__easter">
    &ldquo;Omnia aliena sunt; tempus tantum nostrum est.&rdquo;<br />
    &mdash; <span data-i18n="easter.quote">Tudo &eacute; alheio; apenas o tempo &eacute; nosso.</span>
    <cite><span data-i18n="easter.cite">S&ecirc;neca, Cartas a Luc&iacute;lio, I</span></cite>
  </blockquote>

  <div class="post-it" id="post-it" aria-hidden="true">
    <span data-i18n="postit.quote">Per angusta ad augusta.</span>
    <cite data-i18n="postit.cite">S&ecirc;neca</cite>
  </div>
</section>

<script>
  const postIt = document.getElementById('post-it');
  if (postIt) {
    const observer = new MutationObserver(() => {
      postIt.hidden = document.documentElement.getAttribute('data-theme') === 'dark';
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    postIt.hidden = document.documentElement.getAttribute('data-theme') === 'dark';
  }
</script>

<style>
  .info {
    max-width: 1280px;
    margin: 0 auto;
    min-height: 85vh;
    padding: var(--space-margin-editorial);
    padding-block-start: var(--space-gap-section);
  }

  .info__header {
    margin-bottom: var(--space-gap-section);
    position: relative;
  }

  .info__header::after {
    content: '';
    position: absolute;
    top: -12px;
    right: 10%;
    width: 52px;
    height: 14px;
    background: var(--color-accent-stamp);
    opacity: 0.4;
    transform: rotate(5deg);
    pointer-events: none;
    z-index: 2;
  }

  .info__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-gap-section);
    min-height: 60vh;
    position: relative;
    transform: rotate(0.1deg);
  }

  .info__cards-tape {
    top: -13px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 120px;
  }

  .info__cards::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(50% + 1px);
    width: 1px;
    background: repeating-linear-gradient(
      var(--color-border-primary) 0,
      var(--color-border-primary) 6px,
      transparent 6px,
      transparent 10px
    );
    z-index: 1;
    pointer-events: none;
    opacity: 0.7;
  }

  .info__cards::after {
    content: '';
    position: absolute;
    top: 18%;
    left: 50%;
    width: 50px;
    height: 14px;
    background: var(--color-accent-stamp);
    opacity: 0.45;
    transform: translateX(-50%) rotate(-2deg);
    z-index: 3;
    pointer-events: none;
  }

  .info__card {
    position: relative;
    padding: var(--space-margin-editorial);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    border: var(--space-border-width) solid var(--color-border-primary);
    /* Superficie de papel liso: recorte que se destaca do fundo quadriculado. */
    background-color: var(--color-surface-page);
  }

  .info__card::before {
    content: '';
    position: absolute;
    inset: 2px;
    border: 1px solid var(--color-border-primary);
    transform: rotate(0.3deg);
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }

  .info__card--about {
    background-color: var(--color-surface-page);
    transform: rotate(-0.1deg);
  }

  .info__card--about::after {
    content: '';
    position: absolute;
    top: 52%;
    right: -6px;
    width: 48px;
    height: 14px;
    background: var(--color-accent-stamp);
    opacity: 0.45;
    transform: rotate(3deg);
    z-index: 4;
    pointer-events: none;
  }

  .info__card--contact {
    background-color: var(--color-surface-container);
    transform: rotate(0.15deg);
  }

  .info__card--contact::after {
    content: '';
    position: absolute;
    top: 74%;
    left: -6px;
    width: 54px;
    height: 14px;
    background: var(--color-accent-stamp);
    opacity: 0.45;
    transform: rotate(-3deg);
    z-index: 4;
    pointer-events: none;
  }

  .info__card-label {
    display: block;
    margin-bottom: var(--space-gap-section);
    border-bottom: var(--space-border-width) solid var(--color-border-primary);
    padding-bottom: var(--space-gap-inline);
  }

  .info__contact-lines {
    display: flex;
    flex-direction: column;
  }

  .info__contact-line {
    padding-block: var(--space-gap-inline);
    padding-inline: var(--space-gap-inline);
    transform: rotate(0.15deg);
  }

  .info__contact-line:nth-child(2n) {
    transform: rotate(-0.2deg);
  }

  .info__contact-line:nth-child(even) {
    background-color: var(--color-surface-page);
  }

  .info__contact-line:nth-child(odd) {
    background-color: var(--color-surface-container);
  }

  .info__contact-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-gap-inline);
    text-decoration: none;
  }

  .info__contact-sep {
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-small);
    color: var(--color-text-secondary);
  }

  .info__closing {
    margin-top: var(--space-gap-section);
    text-align: right;
  }

  .info__closing :global(.text[data-voice='serif']) {
    text-shadow: 0.5px 0.5px 0 var(--color-text-primary);
  }

  .info__easter {
    position: relative;
    max-width: 680px;
    margin: var(--space-margin-tecnico) 0 0 auto;
    text-align: right;
    font-family: var(--type-voice-serif);
    font-size: var(--type-size-small);
    font-style: italic;
    color: var(--color-text-secondary);
    opacity: 0.5;
    line-height: 1.6;
    background: linear-gradient(90deg, rgba(230, 57, 70, 0.05) 0, transparent 30px);
  }

  .info__easter::before {
    content: '';
    position: absolute;
    left: -10px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent-stamp);
    opacity: 0.3;
  }

  .info__easter::after {
    content: '';
    position: absolute;
    left: -4px;
    top: 6px;
    width: 100%;
    height: 1px;
    background: var(--color-accent-stamp);
    opacity: 0.25;
  }

  .info__easter cite::after {
    content: '\2588';
    margin-left: 2px;
    color: var(--color-accent-stamp);
    opacity: 0.6;
    animation: cursor-blink 1.2s steps(1) infinite;
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-micro);
    font-style: normal;
    line-height: 1;
    vertical-align: middle;
  }

  @keyframes cursor-blink {
    0%, 49% { opacity: 0.6; }
    50%, 100% { opacity: 0; }
  }

  .info__easter cite {
    display: block;
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-micro);
    font-style: normal;
    color: var(--color-text-secondary);
    margin-block-start: var(--space-gap-inline);
    letter-spacing: var(--type-tracking-navigation);
  }

  @media (width <= 900px) {
    .info {
      padding: var(--space-margin-tecnico);
    }

    .info__card {
      padding: var(--space-gap-section);
    }

    .info__cards {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .info__cards::before {
      top: 50%;
      bottom: auto;
      left: 0;
      right: 0;
      width: auto;
      height: var(--space-border-width);
    }

    .info__cards::after {
      top: 50%;
      left: 18%;
      width: 50px;
      height: 14px;
      transform: translateY(-50%) rotate(1deg);
    }

    .info__card--about::after {
      top: 50%;
      right: auto;
      left: 55%;
      transform: translateY(-50%) rotate(3deg);
    }

    .info__card--contact::after {
      top: 50%;
      left: 35%;
      transform: translateY(-50%) rotate(-3deg);
    }
  }

  @media (width <= 520px) {
    .info {
      padding: var(--space-gap-paragraph);
    }

    .info__card {
      padding: var(--space-gap-paragraph);
    }
  }
  .post-it {
    position: absolute;
    bottom: 40px;
    right: 40px;
    z-index: 2;
    pointer-events: none;
    width: 170px;
    padding: var(--space-gap-paragraph) var(--space-gap-metadata);
    background-color: rgba(244, 241, 234, 0.8);
    border: 1px solid var(--color-border-primary);
    opacity: 0.15;
    transform: rotate(2.5deg);
    font-family: var(--type-voice-serif);
    font-size: var(--type-size-small);
    font-style: italic;
    color: var(--color-text-primary);
    line-height: 1.4;
    transition: opacity 400ms linear;
  }

  .post-it:hover {
    opacity: 0.4;
  }

  .post-it::after {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    width: 22px;
    height: 8px;
    background: var(--color-accent-stamp);
    opacity: 0.35;
    transform: translateX(-50%) rotate(-4deg);
    pointer-events: none;
  }

  .post-it cite {
    display: block;
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-micro);
    font-style: normal;
    color: var(--color-text-secondary);
    margin-top: var(--space-gap-inline);
  }

  @media (width <= 900px) {
    .post-it {
      display: none;
    }
  }
</style>
