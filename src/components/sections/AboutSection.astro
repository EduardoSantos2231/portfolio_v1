---
import EditorialLayout from '../layout/EditorialLayout.astro';
import Surface from '../primitives/Surface.astro';
import Text from '../primitives/Text.astro';
import SectionTitle from '../compounds/SectionTitle.astro';

export interface Props {
  fields: { label: string; value: string; i18nKey: string }[];
}

const { fields } = Astro.props;
---

<EditorialLayout>
  <section class="about" aria-labelledby="about-title">
    <Surface material="container" as="div">
      <SectionTitle label="SOBRE" prefix="slash" i18nKey="about.title" />

      <figure class="about__video">
        <iframe
          src="https://www.youtube.com/embed/dQw4w9WgXcQ"
          title="Video de apresentacao"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope"
          allowfullscreen
        />
        <figcaption class="about__video-caption">
          <Text voice="mono" size="micro" color="secondary" as="span">
            FIG. 01 — VIDEO DE APRESENTACAO
          </Text>
        </figcaption>
      </figure>

      <dl class="about__fields">
        {fields.map(({ label, value, i18nKey }) => (
          <div class="about__row">
            <dt class="about__label">
              <Text voice="mono" size="small" color="secondary" as="span">
                <span data-i18n={i18nKey}>{label}</span>
              </Text>
            </dt>
            <dd class="about__value">
              <Text voice="serif" size="body" color="primary" as="span">
                {value}
              </Text>
            </dd>
          </div>
        ))}
      </dl>
    </Surface>
  </section>
</EditorialLayout>

<style>
  .about {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding: var(--space-margin-editorial) 0;
  }

  .about__video {
    margin-bottom: var(--space-gap-section);
    border: var(--space-border-width) solid var(--color-border-primary);
    aspect-ratio: 4 / 3;
    position: relative;
  }

  .about__video iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .about__video-caption {
    position: absolute;
    bottom: -20px;
    left: 0;
  }

  .about__fields {
    display: flex;
    flex-direction: column;
    padding: var(--space-gap-section);
    background-color: var(--color-surface-page);
    position: relative;
  }

  .about__fields::before {
    content: '';
    position: absolute;
    top: -9px;
    right: 22px;
    width: 38px;
    height: 14px;
    background: var(--color-accent-stamp);
    opacity: 0.45;
    transform: rotate(-2.5deg);
    z-index: 3;
    pointer-events: none;
  }

  .about__fields::after {
    content: '';
    position: absolute;
    top: -10px;
    left: 18px;
    width: 44px;
    height: 15px;
    background: var(--color-accent-stamp);
    opacity: 0.45;
    transform: rotate(3.5deg);
    z-index: 3;
    pointer-events: none;
  }

  .about__row {
    display: flex;
    gap: var(--space-gap-inline);
    align-items: baseline;
    padding-block: var(--space-gap-inline);
    padding-inline: var(--space-gap-inline);
  }

  .about__row:nth-child(even) {
    background-color: var(--color-surface-page);
  }

  .about__row:nth-child(odd) {
    background-color: transparent;
  }

  .about__label {
    min-width: 10ch;
    flex-shrink: 0;
  }

  .about__value :global(.text[data-voice='serif']) {
    text-shadow: 0.5px 0.5px 0 var(--color-text-primary);
  }

  @media (width <= 520px) {
    .about__row {
      flex-direction: column;
      gap: var(--space-gap-inline);
    }
  }
</style>
