---
import ProjectImage from './ProjectImage.astro';
import Text from '../primitives/Text.astro';

export interface ProjectData {
  id: string;
  title: string;
  date: string;
  technologies: string[];
  description?: string;
  image: { src: string; alt: string };
}

export interface Props {
  project: ProjectData;
  isExpanded?: boolean;
}

const { project, isExpanded = false } = Astro.props;
---

<li class={['project-preview', 'reveal', isExpanded ? 'project-preview--expanded' : ''].join(' ')}>
  <span class="project-preview__tape" aria-hidden="true" />

  <ProjectImage
    src={project.image.src}
    alt={project.image.alt}
    caption={project.image.alt}
  />

  <div class="project-preview__meta">
    <Text voice="grotesk" size="subhead" weight="medium" color="primary" as="h3">
      {project.title}
    </Text>

    <div class="project-preview__details">
      <Text voice="mono" size="small" color="secondary" as="span">
        {project.date}
      </Text>
      <span class="sep">{'\u00B7'}</span>
      <Text voice="mono" size="small" color="secondary" as="span">
        {project.technologies.join(' \u00B7 ')}
      </Text>
    </div>

    {project.description && (
      <Text voice="serif" size="small" weight="italic" color="primary" as="p">
        {project.description}
      </Text>
    )}
  </div>
</li>

<style>
  .project-preview {
    --settle-rotate: -0.6deg;
    position: relative;
    padding: var(--space-gap-paragraph);
    border: var(--space-border-width) solid var(--color-border-primary);
    background-color: var(--color-surface-page);
    list-style: none;
    z-index: 0;
    box-shadow: 3px 3px 0 0 color-mix(in srgb, var(--color-border-primary) 55%, transparent);
    transition:
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 220ms ease;
    /* Papel quadriculado dentro do recorte. */
    --_g-fine: color-mix(in srgb, var(--color-grid-line) 14%, transparent);
    --_g-bold: color-mix(in srgb, var(--color-grid-line) 26%, transparent);
    background-image:
      linear-gradient(to right, var(--_g-fine) 0, var(--_g-fine) 1px, transparent 1px),
      linear-gradient(to bottom, var(--_g-fine) 0, var(--_g-fine) 1px, transparent 1px),
      linear-gradient(to right, var(--_g-bold) 0, var(--_g-bold) 1.5px, transparent 1.5px),
      linear-gradient(to bottom, var(--_g-bold) 0, var(--_g-bold) 1.5px, transparent 1.5px);
    background-size:
      var(--graph-cell-fine, 22px) var(--graph-cell-fine, 22px),
      var(--graph-cell-fine, 22px) var(--graph-cell-fine, 22px),
      var(--graph-cell-bold, 110px) var(--graph-cell-bold, 110px),
      var(--graph-cell-bold, 110px) var(--graph-cell-bold, 110px);
  }

  .project-preview::after {
    content: '';
    position: absolute;
    inset: 2px;
    border: 1px solid var(--color-border-primary);
    opacity: 0.45;
    transform: rotate(0.2deg);
    pointer-events: none;
    z-index: 0;
  }

  /* Cascata de entrada por coluna. */
  .project-preview:nth-child(3n + 1) {
    --reveal-delay: 0ms;
  }

  .project-preview:nth-child(3n + 2) {
    --reveal-delay: 90ms;
  }

  .project-preview:nth-child(3n + 3) {
    --reveal-delay: 180ms;
  }

  .project-preview:nth-child(2n) {
    --settle-rotate: 0.7deg;
  }

  .project-preview:nth-child(3n) {
    --settle-rotate: -1deg;
  }

  .project-preview:nth-child(5n) {
    --settle-rotate: 1.1deg;
    z-index: 1;
  }

  /* Hover: o recorte se ajeita reto e "levanta" do papel. */
  .project-preview:hover,
  .project-preview:focus-within {
    z-index: 3;
    transform: translateY(-6px) rotate(0deg) scale(1.02);
    box-shadow:
      6px 8px 0 0 color-mix(in srgb, var(--color-border-primary) 80%, transparent),
      0 10px 24px rgba(0, 0, 0, 0.14);
  }

  .project-preview__tape {
    position: absolute;
    top: -8px;
    left: 14px;
    width: 36px;
    height: 14px;
    background: rgba(123, 201, 66, 0.2);
    z-index: 2;
    transform: rotate(-2deg);
    pointer-events: none;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), width 220ms ease;
  }

  .project-preview:hover .project-preview__tape,
  .project-preview:focus-within .project-preview__tape {
    transform: rotate(-6deg) translateY(-2px);
    width: 44px;
  }

  .project-preview:nth-child(2n) .project-preview__tape {
    left: auto;
    right: 18px;
    background: rgba(230, 57, 70, 0.18);
    transform: rotate(3deg);
  }

  .project-preview__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-gap-inline);
    padding-block-start: var(--space-gap-metadata);
  }

  .project-preview__details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-gap-inline);
  }

  .sep {
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-small);
    color: var(--color-text-secondary);
  }

  .project-preview--expanded {
    grid-row: span 2;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-preview,
    .project-preview__tape {
      transition: none;
    }

    .project-preview:hover,
    .project-preview:focus-within {
      transform: none;
    }
  }

  @media (width <= 520px) {
    .project-preview {
      padding: var(--space-gap-paragraph);
      min-width: 0;
    }
  }
</style>
