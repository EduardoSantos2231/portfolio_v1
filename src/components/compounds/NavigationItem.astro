---
export interface Props {
  href: string;
  label: string;
  active?: boolean;
  i18nKey?: string;
}

const { href, label, active = false, i18nKey } = Astro.props;
---

<a
  href={href}
  class="nav-item"
  data-active={active ? 'true' : undefined}
  aria-current={active ? 'page' : undefined}
>
  <span class="nav-item__label" data-i18n={i18nKey}>{label}</span>
</a>

<style>
  .nav-item {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    padding: var(--space-gap-inline) var(--space-gap-metadata);
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-small);
    font-weight: var(--type-weight-mono);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--type-tracking-navigation);
    transition: color var(--motion-hover);
    flex-shrink: 0;
    min-height: 44px;
    position: relative;
  }

  .nav-item::after {
    content: '\00B7';
    position: absolute;
    right: calc(-1 * var(--space-gap-inline));
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-secondary);
    font-family: var(--type-voice-mono);
    pointer-events: none;
    opacity: 0.4;
  }

  .nav-item:last-child::after {
    display: none;
  }

  .nav-item:hover {
    color: var(--color-accent-stamp);
    animation: glitch-pulse 150ms steps(1) 1;
  }

  .nav-item[data-active='true'] {
    color: var(--color-accent-stamp);
  }

  .nav-item[data-active='true']::before {
    content: '[';
    margin-right: 1px;
    color: var(--color-accent-stamp);
  }

  .nav-item[data-active='true']::after {
    content: ']';
    display: inline;
    position: static;
    transform: none;
    margin-left: 1px;
    color: var(--color-accent-stamp);
  }

  .nav-item:focus-visible {
    outline: 2px solid var(--color-accent-stamp);
    outline-offset: 2px;
  }

  .nav-item__label {
    white-space: nowrap;
  }

  @keyframes glitch-pulse {
    0%, 100% { transform: translate(0, 0); }
    20% { transform: translate(-1px, 0); }
    40% { transform: translate(1px, 0); }
    60% { transform: translate(0, 1px); }
    80% { transform: translate(0, -1px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-item:hover {
      animation: none;
    }
  }
</style>
