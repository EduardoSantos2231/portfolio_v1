---
import '../../styles/tokens.css';
import '../../styles/reset.css';
import '../../styles/layout.css';
import '../../styles/collage.css';
import NavigationItem from '../compounds/NavigationItem.astro';
import LangToggle from '../compounds/LangToggle.astro';
import ThemeToggle from '../compounds/ThemeToggle.astro';
import MobileNav from './MobileNav.astro';

interface NavLink {
  href: string;
  label: string;
  i18nKey?: string;
}

interface FooterMeta {
  portfolioName: string;
  date: string;
  version: string;
}

interface Props {
  navLinks: NavLink[];
  footerMeta: FooterMeta;
}

const { navLinks, footerMeta } = Astro.props;
---

<html lang="pt-BR" data-lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{footerMeta.portfolioName}</title>
  </head>
  <body>
    <svg xmlns="http://www.w3.org/2000/svg" style="position:absolute;width:0;height:0" aria-hidden="true">
      <filter id="paper-grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
        <feComponentTransfer><feFuncA type="linear" slope="0.08" /></feComponentTransfer>
      </filter>
    </svg>
    <div class="grid-overlay" aria-hidden="true" />
    <div class="paper-noise" style="filter:url(#paper-grain)" aria-hidden="true" />
    <nav class="nav" aria-label="Navegacao principal" data-i18n-aria="nav.arialabel">
      <div class="nav__progress" aria-hidden="true">
        <div class="nav__progress-fill" />
      </div>
      <div class="nav__items">
        {navLinks.map((link) => (
          <NavigationItem href={link.href} label={link.label} i18nKey={link.i18nKey} />
        ))}
      </div>
      <div class="nav__lang">
        <LangToggle />
      </div>
    </nav>

    <MobileNav navLinks={navLinks} />

    <main id="main-content" class="main-content">
      <slot />
    </main>

    <footer class="footer">
      <span class="footer__nav" data-i18n="footer.nav">INFO · TRAJETORIA · PROJETOS</span>
      <span class="footer__meta">Eduardo Nascimento · {footerMeta.date} · v{footerMeta.version}</span>
    </footer>

    <ThemeToggle />
  </body>
</html>

<script>
  function applyTranslations() {
    const html = document.documentElement;
    const lang = html.getAttribute('data-lang') || 'pt';
    const isEn = lang === 'en';

    const map: Record<string, string> = isEn ? {
      'nav.arialabel': 'Main navigation',
      'nav.info': 'INFO',
      'nav.carreira': 'PATH',
      'nav.projetos': 'WORK',
      'info.title': 'INFO',
      'about.cardLabel': 'DATASHEET',
      'about.nome': 'NAME',
      'about.formacao': 'EDUCATION',
      'about.localizacao': 'LOCATION',
      'career.arialabel': 'Career path',
      'career.title': 'PATH',
      'career.cardLabel': 'DATASHEET',
      'career.focus': 'CURRENT FOCUS',
      'career.seeking': 'SEEKING',
      'career.languages': 'LANGUAGES',
      'career.idiomas': 'LANGUAGES',
      'career.interesses': 'INTERESTS',
      'career.videoTitle': 'Presentation video',
      'career.videoCaption': 'FIG. 02 \u2014 PRESENTATION',
      'projects.title': 'WORK',
      'projects.total': 'REGISTERED PROJECTS',
      'projects.updated': 'UPDATED',
      'contact.cardLabel': 'CONTACT',
      'contact.email': 'EMAIL',
      'contact.github': 'GITHUB',
      'contact.linkedin': 'LINKEDIN',
      'contact.localizacao': 'LOCATION',
      'footer.nav': 'INFO \u00b7 PATH \u00b7 WORK',
      'residual.arialabel': 'Visual break',
      'theme.light': 'LIGHT',
      'theme.dark': 'DARK',
      'lang.toggle': 'Switch language',
      'info.arialabel': 'Information',
      'mobile.open': 'Open navigation menu',
      'mobile.close': 'Close navigation menu',
      'easter.quote': 'Everything is alien; only time is ours.',
      'easter.cite': 'Seneca, Letters to Lucilius, I',
      'postit.quote': 'Through narrow paths, to the heights.',
      'postit.cite': 'Seneca',
    } : {
      'nav.arialabel': 'Navegacao principal',
      'nav.info': 'INFO',
      'nav.carreira': 'TRAJETORIA',
      'nav.projetos': 'PROJETOS',
      'info.title': 'INFO',
      'about.cardLabel': 'FICHA TECNICA',
      'about.nome': 'NOME',
      'about.formacao': 'FORMACAO',
      'about.localizacao': 'LOCALIZACAO',
      'career.arialabel': 'Trajetoria profissional',
      'career.title': 'TRAJETORIA',
      'career.cardLabel': 'FICHA TECNICA',
      'career.focus': 'FOCO ATUAL',
      'career.seeking': 'BUSCANDO',
      'career.languages': 'LINGUAGENS',
      'career.idiomas': 'IDIOMAS',
      'career.interesses': 'INTERESSES',
      'career.videoTitle': 'Video de apresentacao',
      'career.videoCaption': 'FIG. 02 \u2014 APRESENTACAO',
      'projects.title': 'PROJETOS',
      'projects.total': 'PROJETOS REGISTRADOS',
      'projects.updated': 'ATUALIZADO EM',
      'contact.cardLabel': 'CONTATO',
      'contact.email': 'EMAIL',
      'contact.github': 'GITHUB',
      'contact.linkedin': 'LINKEDIN',
      'contact.localizacao': 'LOCALIZACAO',
      'footer.nav': 'INFO \u00b7 TRAJETORIA \u00b7 PROJETOS',
      'residual.arialabel': 'Intervalo visual',
      'theme.light': 'CLARO',
      'theme.dark': 'ESCURO',
      'lang.toggle': 'Alternar idioma',
      'info.arialabel': 'Informacoes',
      'mobile.open': 'Abrir menu de navegacao',
      'mobile.close': 'Fechar menu de navegacao',
      'easter.quote': 'Tudo \u00e9 alheio; apenas o tempo \u00e9 nosso.',
      'easter.cite': 'S\u00eacheca, Cartas a Luc\u00edlio, I',
      'postit.quote': 'Per angusta ad augusta.',
      'postit.cite': 'S\u00eacheca',
    };

    html.setAttribute('lang', isEn ? 'en' : 'pt-BR');

    for (const el of document.querySelectorAll<HTMLElement>('[data-i18n]')) {
      const key = el.dataset.i18n;
      if (key && map[key]) {
        el.textContent = map[key];
      }
    }

    for (const el of document.querySelectorAll<HTMLElement>('[data-i18n-aria]')) {
      const key = el.dataset.i18nAria;
      if (key && map[key]) {
        el.setAttribute('aria-label', map[key]);
      }
    }

    const totalEl = document.getElementById('projects-total');
    if (totalEl) {
      const count = totalEl.dataset.count || '0';
      const label = isEn ? 'REGISTERED PROJECTS' : 'PROJETOS REGISTRADOS';
      totalEl.textContent = `${count} ${label}`;
    }

    const updatedEl = document.getElementById('projects-updated');
    if (updatedEl) {
      const date = updatedEl.dataset.date || '';
      const prefix = isEn ? 'UPDATED' : 'ATUALIZADO EM';
      updatedEl.textContent = `${prefix} ${date}`;
    }
  }

  function setupScrollSpy() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.nav-item');
    const progressFill = document.querySelector<HTMLElement>('.nav__progress-fill');

    const sections = [
      document.getElementById('info'),
      document.getElementById('carreira'),
      document.getElementById('projetos'),
    ].filter(Boolean) as HTMLElement[];

    function updateActive() {
      const threshold = window.scrollY + window.innerHeight * 0.4;
      let activeHash = '#info';
      const scrollBottom = window.scrollY + window.innerHeight;
      const docBottom = document.body.scrollHeight - 40;

      if (scrollBottom >= docBottom) {
        activeHash = '#projetos';
      } else {
        for (let i = 0; i < sections.length; i++) {
          const target = sections[i];
          if (!target) continue;
          if (target.getBoundingClientRect().top + window.scrollY <= threshold) {
            activeHash = '#' + target.id;
          }
        }
      }

      for (const link of links) {
        const href = link.getAttribute('href') || '';
        const hashIndex = href.indexOf('#');
        const linkHash = hashIndex >= 0 ? href.slice(hashIndex) : '';
        link.dataset.active = linkHash === activeHash ? 'true' : 'false';
      }

      if (progressFill) {
        const docHeight = document.body.scrollHeight - window.innerHeight;
        const scrollY = window.scrollY;
        const pct = docHeight > 0 ? Math.min(scrollY / docHeight, 1) : 0;
        progressFill.style.transform = `scaleX(${pct})`;
        const progressBar = document.querySelector<HTMLElement>('.nav__progress');
        if (progressBar) {
          progressBar.dataset.complete = pct >= 0.99 ? 'true' : '';
        }
      }
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  }

  function observeLangChange() {
    const observer = new MutationObserver(() => {
      applyTranslations();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });
    applyTranslations();
  }

  function setupCollageReveal() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll<HTMLElement>('.reveal');

    if (prefersReduced || !('IntersectionObserver' in window)) {
      for (const el of targets) {
        el.classList.add('is-settled');
      }
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.add('is-pasted');
            el.addEventListener(
              'animationend',
              () => {
                el.classList.add('is-settled');
                el.classList.remove('is-pasted');
              },
              { once: true }
            );
            observer.unobserve(el);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    for (const el of targets) {
      observer.observe(el);
    }
  }

  setupScrollSpy();
  observeLangChange();
  setupCollageReveal();
</script>

<style>
  .grid-overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    --_fine: color-mix(in srgb, var(--color-grid-line) 22%, transparent);
    --_bold: color-mix(in srgb, var(--color-grid-line) 40%, transparent);
    background-image:
      linear-gradient(to right, var(--_fine) 0, var(--_fine) 1px, transparent 1px),
      linear-gradient(to bottom, var(--_fine) 0, var(--_fine) 1px, transparent 1px),
      linear-gradient(to right, var(--_bold) 0, var(--_bold) 1.5px, transparent 1.5px),
      linear-gradient(to bottom, var(--_bold) 0, var(--_bold) 1.5px, transparent 1.5px);
    background-size:
      var(--graph-cell-fine, 22px) var(--graph-cell-fine, 22px),
      var(--graph-cell-fine, 22px) var(--graph-cell-fine, 22px),
      var(--graph-cell-bold, 110px) var(--graph-cell-bold, 110px),
      var(--graph-cell-bold, 110px) var(--graph-cell-bold, 110px);
    opacity: 0.55;
  }

  [data-theme='dark'] .grid-overlay {
    opacity: 0.4;
  }

  .paper-noise {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.03;
    mix-blend-mode: multiply;
  }

  body {
    position: relative;
    background-color: var(--color-surface-page);
    counter-reset: section-counter;
  }

  body::after {
    content: '';
    position: fixed;
    pointer-events: none;
    z-index: 0;
    inset: 0;
    opacity: 0.05;
    background:
      linear-gradient(135deg, transparent 48%, var(--color-accent-stamp) 48%, var(--color-accent-stamp) 52%, transparent 52%) 85% 12% / 80px 80px no-repeat,
      linear-gradient(315deg, transparent 48%, var(--color-accent-stamp) 48%, var(--color-accent-stamp) 52%, transparent 52%) 8% 75% / 50px 50px no-repeat,
      linear-gradient(135deg, transparent 48%, var(--color-accent-stamp) 48%, var(--color-accent-stamp) 52%, transparent 52%) 60% 88% / 60px 60px no-repeat;
    transform: rotate(-8deg);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.06;
    background:
      /* stroke 1 — thick diagonal, top-right */
      linear-gradient(25deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 2px, transparent 2px) 72% 8% / 90px 10px no-repeat,
      /* stroke 2 — thin, mid-left */
      linear-gradient(-15deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 1px, transparent 1px) 12% 40% / 60px 8px no-repeat,
      /* stroke 3 — thick, bottom-center */
      linear-gradient(40deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 3px, transparent 3px) 55% 82% / 100px 12px no-repeat,
      /* stroke 4 — thin, top-left */
      linear-gradient(-30deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 1.5px, transparent 1.5px) 18% 15% / 70px 6px no-repeat,
      /* stroke 5 — thick, mid-right */
      linear-gradient(55deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 2px, transparent 2px) 88% 55% / 80px 10px no-repeat,
      /* stroke 6 — very thin accent */
      linear-gradient(-45deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 0.8px, transparent 0.8px) 40% 68% / 50px 5px no-repeat,
      /* stroke 7 — thick bottom-left */
      linear-gradient(10deg, transparent 0, var(--color-accent-stamp) 0, var(--color-accent-stamp) 3px, transparent 3px) 5% 90% / 110px 14px no-repeat;
  }

  .main-content {
    position: relative;
    z-index: 1;
    padding-block-start: 56px;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    z-index: 10;
    background-color: var(--color-surface-page);
    border-bottom: var(--space-border-width) solid var(--color-border-primary);
  }

  .nav__items {
    display: flex;
    gap: var(--space-gap-inline);
    padding: var(--space-gap-inline) var(--space-gap-paragraph);
    padding-right: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .nav__lang {
    display: flex;
    align-items: center;
    padding: var(--space-gap-inline) var(--space-gap-paragraph);
    padding-left: 0;
    margin-left: auto;
  }

  .nav__items::-webkit-scrollbar {
    display: none;
  }

  @media (width <= 900px) {
    .nav__items {
      display: none;
    }

    .nav__lang {
      position: fixed;
      top: var(--space-gap-paragraph);
      right: var(--space-gap-paragraph);
      z-index: 11;
      padding: 0;
    }
  }

  @media (width > 900px) {
    .nav::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.12;
      background-image: repeating-linear-gradient(
        45deg,
        transparent,
        transparent 4px,
        var(--color-border-primary) 4px,
        var(--color-border-primary) 5px
      );
    }
  }

  .footer__meta:hover::after {
    content: '[build: 2026-07-17]';
    position: absolute;
    left: 0;
    top: -16px;
    font-family: var(--type-voice-mono);
    font-size: 10px;
    color: var(--color-accent-stamp);
    white-space: nowrap;
    opacity: 0.7;
    letter-spacing: var(--type-tracking-navigation);
  }

  .nav__progress {
    position: absolute;
    bottom: calc(-1 * var(--space-border-width));
    left: 0;
    right: 0;
    height: var(--space-border-width);
    background-color: var(--color-border-primary);
  }

  .nav__progress-fill {
    height: 100%;
    background-color: var(--color-accent-stamp);
    transform-origin: left;
    transform: scaleX(0);
  }

  .nav__progress[data-complete='true']::after {
    content: '[EOF]';
    position: absolute;
    right: 8px;
    top: 4px;
    font-family: var(--type-voice-mono);
    font-size: 10px;
    color: var(--color-accent-stamp);
    opacity: 0.6;
    letter-spacing: var(--type-tracking-navigation);
  }

  .footer {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-gap-paragraph) var(--space-margin-editorial);
    border-top: var(--space-border-width) solid var(--color-border-primary);
    background-color: var(--color-surface-page);
    font-family: var(--type-voice-mono);
    font-size: var(--type-size-micro);
    color: var(--color-text-secondary);
    letter-spacing: var(--type-tracking-navigation);
  }
</style>
